generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  ASSET_MANAGER
  DEPARTMENT_HEAD
  EMPLOYEE
}

enum EntityStatus {
  ACTIVE
  INACTIVE
  DELETED
}

enum AssetStatus {
  AVAILABLE
  ALLOCATED
  RESERVED
  UNDER_MAINTENANCE
  LOST
  RETIRED
  DISPOSED
}

enum TransferStatus {
  REQUESTED
  APPROVED
  REJECTED
  COMPLETED
}

enum MaintenanceStatus {
  SCHEDULED
  APPROVED
  ASSIGNED
  IN_PROGRESS
  RESOLVED
  COMPLETED
  CANCELLED
}

enum MaintenancePriority {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum AuditCycleStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum AssetVerificationStatus {
  PENDING
  VERIFIED
  MISSING
  DAMAGED
  DISPOSED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

// ─── Department ───────────────────────────────────────────────────────────────

model Department {
  id        Int          @id @default(autoincrement())
  name      String       @unique
  parentId  Int?
  parent    Department?  @relation("DeptHierarchy", fields: [parentId], references: [id])
  children  Department[] @relation("DeptHierarchy")
  headId    Int?
  head      User?        @relation("DeptHead", fields: [headId], references: [id])
  status    EntityStatus @default(ACTIVE)
  employees User[]       @relation("DeptEmployees")
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  deletedAt DateTime?

  @@index([status])
  @@index([parentId])
}

// ─── User ─────────────────────────────────────────────────────────────────────

model User {
  id           Int          @id @default(autoincrement())
  name         String
  email        String       @unique
  password     String
  role         Role         @default(EMPLOYEE)
  status       EntityStatus @default(ACTIVE)
  departmentId Int?
  department   Department?  @relation("DeptEmployees", fields: [departmentId], references: [id])
  headOf       Department[] @relation("DeptHead")
  allocations  Allocation[] @relation("AllocatedTo")
  allocatedBy  Allocation[] @relation("AllocatedBy")
  bookings     Booking[]
  auditLogs    AuditLog[]
  notifications Notification[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  deletedAt    DateTime?

  @@index([role])
  @@index([status])
  @@index([departmentId])
}

// ─── AssetCategory ────────────────────────────────────────────────────────────

model AssetCategory {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  fields      Json?
  assets      Asset[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── Vendor ───────────────────────────────────────────────────────────────────

model Vendor {
  id             Int      @id @default(autoincrement())
  name           String   @unique
  contactPerson  String?
  email          String?
  phone          String?
  address        String?
  supportEmail   String?
  supportPhone   String?
  website        String?
  assets         Asset[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// ─── Asset ────────────────────────────────────────────────────────────────────

model Asset {
  id              Int                @id @default(autoincrement())
  assetTag        String             @unique
  name            String
  categoryId      Int
  category        AssetCategory      @relation(fields: [categoryId], references: [id])
  serialNumber    String?            @unique
  qrCode          String?            @unique
  qrCodeUrl       String?
  acquisitionDate DateTime?
  acquisitionCost Decimal?           @db.Decimal(12, 2)
  condition       String?
  location        String?
  departmentId    Int?
  isBookable      Boolean            @default(false)
  status          AssetStatus        @default(AVAILABLE)
  photoUrl        String?
  warrantyExpiry  DateTime?
  warrantyStart   DateTime?
  vendorId        Int?
  vendor          Vendor?            @relation(fields: [vendorId], references: [id])
  amcExpiry       DateTime?
  invoiceNumber   String?
  customFields    Json?
  allocations     Allocation[]
  transfers       TransferRequest[]
  maintenances    MaintenanceRecord[]
  bookings        Booking[]
  auditItems      AuditItem[]
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  deletedAt       DateTime?

  @@index([status])
  @@index([categoryId])
  @@index([departmentId])
  @@index([location])
  @@index([isBookable])
  @@index([deletedAt])
  @@index([warrantyExpiry])
  @@index([vendorId])
}

// ─── Allocation ───────────────────────────────────────────────────────────────

model Allocation {
  id                 Int       @id @default(autoincrement())
  assetId            Int
  asset              Asset     @relation(fields: [assetId], references: [id])
  allocatedToUserId  Int?
  allocatedToUser    User?     @relation("AllocatedTo", fields: [allocatedToUserId], references: [id])
  allocatedToDeptId  Int?
  allocatedByUserId  Int?
  allocatedByUser    User?     @relation("AllocatedBy", fields: [allocatedByUserId], references: [id])
  expectedReturnDate DateTime?
  actualReturnDate   DateTime?
  conditionAtIssue   String?
  conditionNotes     String?
  isActive           Boolean   @default(true)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([assetId, isActive])
  @@index([allocatedToUserId])
  @@index([allocatedToDeptId])
  @@index([isActive])
  @@index([expectedReturnDate])
}

// ─── TransferRequest ──────────────────────────────────────────────────────────

model TransferRequest {
  id           Int            @id @default(autoincrement())
  assetId      Int
  asset        Asset          @relation(fields: [assetId], references: [id])
  fromUserId   Int?
  toUserId     Int?
  fromDeptId   Int?
  toDeptId     Int?
  requestedById Int?
  status       TransferStatus @default(REQUESTED)
  reason       String?
  rejectionNote String?
  requestedAt  DateTime       @default(now())
  resolvedAt   DateTime?
  updatedAt    DateTime       @updatedAt

  @@index([assetId])
  @@index([status])
  @@index([requestedById])
}

// ─── MaintenanceRecord ────────────────────────────────────────────────────────

model MaintenanceRecord {
  id               Int                  @id @default(autoincrement())
  assetId          Int
  asset            Asset                @relation(fields: [assetId], references: [id])
  scheduledDate    DateTime
  completedDate    DateTime?
  status           MaintenanceStatus    @default(SCHEDULED)
  priority         MaintenancePriority  @default(MEDIUM)
  description      String
  vendor           String?
  estimatedCost    Decimal?             @db.Decimal(12, 2)
  actualCost       Decimal?             @db.Decimal(12, 2)
  repairCost       Decimal?             @db.Decimal(12, 2)
  downtimeHours    Decimal?             @db.Decimal(8, 2)
  technicianName   String?
  technicianNotes  String?
  completionNotes  String?
  resolutionNotes  String?
  scheduledById    Int?
  assignedToId     Int?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  @@index([assetId])
  @@index([status])
  @@index([priority])
  @@index([scheduledDate])
}

// ─── Booking ──────────────────────────────────────────────────────────────────

model Booking {
  id          Int           @id @default(autoincrement())
  assetId     Int
  asset       Asset         @relation(fields: [assetId], references: [id])
  bookedById  Int
  bookedBy    User          @relation(fields: [bookedById], references: [id])
  startTime   DateTime
  endTime     DateTime
  purpose     String?
  status      BookingStatus @default(PENDING)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([assetId, startTime, endTime])
  @@index([bookedById])
  @@index([status])
}

// ─── AuditCycle ───────────────────────────────────────────────────────────────

model AuditCycle {
  id             Int               @id @default(autoincrement())
  title          String
  description    String?
  status         AuditCycleStatus  @default(PLANNED)
  startDate      DateTime
  endDate        DateTime
  departmentId   Int?
  location       String?
  createdById    Int?
  items          AuditItem[]
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([status])
  @@index([departmentId])
  @@index([startDate, endDate])
}

model AuditItem {
  id               Int                     @id @default(autoincrement())
  auditCycleId     Int
  auditCycle       AuditCycle              @relation(fields: [auditCycleId], references: [id])
  assetId          Int
  asset            Asset                   @relation(fields: [assetId], references: [id])
  assignedToId     Int?
  verificationStatus AssetVerificationStatus @default(PENDING)
  notes            String?
  verifiedAt       DateTime?
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  @@unique([auditCycleId, assetId])
  @@index([auditCycleId])
  @@index([assetId])
  @@index([verificationStatus])
}

// ─── AuditLog ─────────────────────────────────────────────────────────────────

model AuditLog {
  id         Int      @id @default(autoincrement())
  action     String
  entityType String
  entityId   Int
  userId     Int?
  user       User?    @relation(fields: [userId], references: [id])
  oldValue   Json?
  newValue   Json?
  ipAddress  String?
  userAgent  String?
  requestId  String?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

// ─── Notification ─────────────────────────────────────────────────────────────

model Notification {
  id         Int      @id @default(autoincrement())
  userId     Int
  user       User     @relation(fields: [userId], references: [id])
  title      String
  message    String
  type       String
  isRead     Boolean  @default(false)
  isArchived Boolean  @default(false)
  entityType String?
  entityId   Int?
  createdAt  DateTime @default(now())

  @@index([userId, isRead])
  @@index([userId, isArchived])
  @@index([createdAt])
}
